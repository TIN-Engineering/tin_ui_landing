# TIN Landing — Client-side environment (all VITE_ prefixed vars ship in the browser bundle).

# Redirect target for the "Start Building" / "Sign Up" CTAs.
VITE_SIGNUP_URL=https://app.paywithtin.com/signup

# CRM Lead API (Contact Sales form) — consumed in a future task.
VITE_CRM_API_URL=https://api.paywithtin.com/crm
VITE_CRM_API_KEY=replace-with-scoped-lead-write-key

# Google Analytics 4 Measurement ID — consumed in a future task.
VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
